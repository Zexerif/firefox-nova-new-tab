{
  "manifest_version": 2,
  "name": "Nova Minimal New Tab",
  "version": "1.0",
  "description": "A clean, minimalist, distraction-free new tab page styled with the Firefox Nova design system.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nova-minimal@quinn.com",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}